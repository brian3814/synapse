{
  "name": "synapse-kg",
  "version": "0.8.0",
  "description": "MCP server for Synapse — local-first knowledge graph with entity extraction and graph intelligence",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brian3814/synapse.git",
    "directory": "packages/synapse-mcp"
  },
  "keywords": ["mcp", "knowledge-graph", "synapse", "sqlite", "local-first"],
  "mcpName": "io.github.brian3814/synapse",
  "bin": {
    "synapse-kg": "./dist/index.js"
  },
  "files": ["dist/", "manifest.json"],
  "scripts": {
    "build": "node build.mjs && esbuild ../../electron/embeddings/onnx-worker.ts --bundle --platform=node --outfile=dist/onnx-worker.cjs --format=cjs --packages=external && npm rebuild better-sqlite3",
    "bundle": "npm run build && npx @anthropic-ai/mcpb pack",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^12.9.0",
    "sqlite-vec": "^0.1.9"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^3.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "esbuild": "^0.25.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
